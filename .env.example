# Copie este arquivo para `.env` e ajuste os valores.
# O arquivo `.env` é local (gitignore) — nunca commitar.
#
#   Windows:  copy .env.example .env
#   Linux/mac: cp .env.example .env
#
# Reinicie `npm run dev` após alterar qualquer VITE_*.

# API REST — sem barra no final
# Local (afro90sBackend na máquina):
VITE_API_BASE_URL=http://localhost:3000
# Dev na AWS (alternativa — obter do SSM):
# VITE_API_BASE_URL=https://xxxxxxxx.execute-api.us-east-1.amazonaws.com/dev

# CDN de imagens de produto — sem barra no final
# Dev na AWS: aws ssm get-parameter --name "/afro90s/dev/assets-cdn-url" ...
VITE_ASSETS_CDN_URL=

# WhatsApp da loja — somente dígitos com DDI (checkout + footer)
VITE_WHATSAPP_NUMBER=

# Instagram (opcional — padrão no código: https://www.instagram.com/afroo90s/)
# VITE_INSTAGRAM_URL=https://www.instagram.com/afroo90s/

# Cognito (admin) — task 11; pode deixar vazio em dev local
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REGION=us-east-1
